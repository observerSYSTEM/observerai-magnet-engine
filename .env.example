APP_NAME=ObserverAI Magnet Engine
APP_ENV=dev
DEBUG=true
DATABASE_URL=sqlite:///./observerai.db

# Production:
# APP_ENV=production
# DEBUG=false

TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
TELEGRAM_ALERTS_ENABLED=false

MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
MT5_TERMINAL_PATH=C:\Program Files\MetaTrader 5\terminal64.exe
API_BASE_URL=http://127.0.0.1:8000

STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
FRONTEND_BASE_URL=http://127.0.0.1:3000
CORS_ALLOWED_ORIGINS=http://127.0.0.1:3000,https://your-frontend.vercel.app

AUTH_JWT_SECRET=change-me-observerai-jwt-secret
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=60

OPERATOR_EMAIL=operator@example.com
OPERATOR_PASSWORD=change-me-strong-password
OPERATOR_ROLE=admin

RUNNER_INTERVAL_SECONDS=60
DEFAULT_SYMBOL=XAUUSD
LONDON_UTC_OFFSET=0
ADR_LOOKBACK_DAYS=5
